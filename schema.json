{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://m3m3tic.dev/schemas/v0.4.0/cr3st4n1.schema.json",
  "title": "cr3st4n1 File Format v0.4.0",
  "description": "Schema for the .cr3st4n1 identity credential file format, version 0.4.0.",
  "type": "object",
  "required": ["cr3st4n1", "identity", "device", "trust", "_signature"],
  "additionalProperties": false,
  "properties": {
    "cr3st4n1": {
      "type": "object",
      "description": "File format metadata block.",
      "required": ["version", "created_at"],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "description": "Semantic version of the cr3st4n1 spec this file conforms to.",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "created_at": {
          "type": "string",
          "description": "ISO 8601 timestamp when this file was created.",
          "format": "date-time"
        },
        "generator": {
          "type": "object",
          "description": "Tool that generated this file.",
          "properties": {
            "tool": { "type": "string" },
            "version": { "type": "string" }
          },
          "additionalProperties": false
        }
      }
    },
    "identity": {
      "type": "object",
      "description": "Identity claim for the credential holder.",
      "required": ["type", "display_name", "email", "verification"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "The type of identity this credential represents.",
          "enum": ["human", "ai_agent", "organization"]
        },
        "display_name": {
          "type": "string",
          "description": "Human-readable name for the identity."
        },
        "email": {
          "type": "string",
          "description": "Contact email for the identity holder.",
          "format": "email"
        },
        "organization": {
          "type": "string",
          "description": "Optional organization affiliation."
        },
        "verification": {
          "type": "object",
          "description": "Verification claims and provider attestations.",
          "required": ["level", "providers"],
          "additionalProperties": false,
          "properties": {
            "level": {
              "type": "string",
              "description": "Highest verification level achieved.",
              "enum": ["self_declared", "email_verified", "contract", "identity_document", "notarized"]
            },
            "providers": {
              "type": "array",
              "description": "List of verification providers that have attested this identity.",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["type", "provider"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["e_signature", "membership", "gov_id", "notary", "platform_registration", "jurisdiction_license"]
                  },
                  "provider": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "ai_agent_metadata": {
          "type": "object",
          "description": "Metadata required when identity.type is 'ai_agent'. Contains operator linkage and autonomy parameters.",
          "required": ["operator_ref"],
          "additionalProperties": false,
          "properties": {
            "operator_ref": {
              "type": "string",
              "description": "SHA-256 hash of the human operator's .cr3st4n1 file."
            },
            "model": {
              "type": "string",
              "description": "AI model identifier (e.g. 'claude-opus-4-6')."
            },
            "autonomy_level": {
              "type": "string",
              "description": "Level of autonomy granted to the AI agent.",
              "enum": ["supervised", "semi_autonomous", "autonomous"]
            },
            "deployer": {
              "type": "string",
              "description": "Entity under whose authority the AI agent operates."
            }
          }
        },
        "licenses": {
          "type": "array",
          "description": "Optional professional or jurisdictional licenses held by the identity.",
          "items": {
            "type": "object",
            "required": ["jurisdiction", "authority", "permit_id"],
            "additionalProperties": false,
            "properties": {
              "jurisdiction": { "type": "string" },
              "authority": { "type": "string" },
              "permit_id": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        }
      }
    },
    "device": {
      "type": "object",
      "description": "Device binding information for the credential.",
      "required": ["binding_level", "registered_at"],
      "additionalProperties": false,
      "properties": {
        "binding_level": {
          "type": "string",
          "description": "How strongly the credential is bound to a specific device.",
          "enum": ["fingerprinted", "attested", "none", "cloud"]
        },
        "hardware_fingerprint": {
          "type": "string",
          "description": "Device hardware fingerprint. Required when binding_level is 'fingerprinted' or 'attested'."
        },
        "registered_at": {
          "type": "string",
          "description": "When this device binding was first registered.",
          "format": "date-time"
        },
        "last_seen": {
          "type": "string",
          "description": "Last time this device was seen active.",
          "format": "date-time"
        }
      }
    },
    "trust": {
      "type": "object",
      "description": "Trust level and credential chain.",
      "required": ["level", "credential_chain"],
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "integer",
          "description": "Numeric trust level from 0 (untrusted) to 5 (fully verified).",
          "minimum": 0,
          "maximum": 5
        },
        "credential_chain": {
          "type": "array",
          "description": "Chain of credentials establishing trust provenance.",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["issuer", "issued_at", "method"],
            "additionalProperties": true,
            "properties": {
              "issuer": {
                "type": "string",
                "description": "Entity that issued this credential."
              },
              "issued_at": {
                "type": "string",
                "description": "When this credential was issued.",
                "format": "date-time"
              },
              "method": {
                "type": "string",
                "description": "Method used to verify and issue the credential."
              }
            }
          }
        }
      }
    },
    "_signature": {
      "type": "object",
      "description": "Cryptographic signature over the entire file contents (excluding this block).",
      "required": ["signer", "algorithm", "signed_at", "signature"],
      "additionalProperties": false,
      "properties": {
        "signer": {
          "type": "string",
          "description": "Identifier of the signing party."
        },
        "algorithm": {
          "type": "string",
          "description": "Signing algorithm used. Must be Ed25519.",
          "const": "Ed25519"
        },
        "signed_at": {
          "type": "string",
          "description": "When the signature was produced.",
          "format": "date-time"
        },
        "signature": {
          "type": "string",
          "description": "Base64-encoded Ed25519 signature."
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "identity": {
            "properties": { "type": { "const": "ai_agent" } },
            "required": ["type"]
          }
        }
      },
      "then": {
        "properties": {
          "identity": {
            "required": ["type", "display_name", "email", "verification", "ai_agent_metadata"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "device": {
            "properties": { "binding_level": { "const": "fingerprinted" } },
            "required": ["binding_level"]
          }
        }
      },
      "then": {
        "properties": {
          "device": {
            "required": ["binding_level", "registered_at", "hardware_fingerprint"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "device": {
            "properties": { "binding_level": { "const": "attested" } },
            "required": ["binding_level"]
          }
        }
      },
      "then": {
        "properties": {
          "device": {
            "required": ["binding_level", "registered_at", "hardware_fingerprint"]
          }
        }
      }
    }
  ]
}
